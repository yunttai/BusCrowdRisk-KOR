# 공공데이터포털(data.go.kr)에서 발급받은 일반 인증키.
# GBIS 버스 도착/위치/노선/정류소, 기상청, 특일 정보처럼 data.go.kr API 호출에 사용한다.
PUBLIC_DATA_SERVICE_KEY=

# 공공데이터 API 요청 타임아웃(초).
# API 응답이 이 시간보다 늦으면 실패로 처리한다.
PUBLIC_DATA_TIMEOUT_SECONDS=10

# SQLite 데이터베이스 파일 경로.
# 수집한 버스 위치/도착 스냅샷, 전처리 feature, 학습용 테이블을 저장한다.
BUSSEAT_DB_PATH=data/busseat.db

# data.go.kr이 아닌 외부 사이트 키는 따로 둔다.

# 국가교통정보센터 ITS Open API 키.
# 도로 소통/교통 정체 정보 수집에 사용한다.
ITS_API_KEY=

# 경기데이터드림(data.gg.go.kr) API 키.
# 경기도 데이터드림에서 제공하는 노선별 이용객, 돌발정보, 도로구간 등 보조 데이터 수집에 사용한다.
DATA_GG_SERVICE_KEY=
